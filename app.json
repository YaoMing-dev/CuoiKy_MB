{
  "expo": {
    "name": "ExploreEase",
    "slug": "CuoiKy",
    "owner": "meanlee",
    "scheme": "exploreease",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90D9"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ExploreEase needs your location to find nearby places.",
        "NSCameraUsageDescription": "ExploreEase needs camera access to scan QR codes.",
        "NSUserNotificationsUsageDescription": "ExploreEase needs notification permission to send you event reminders and updates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A90D9"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ExploreEase needs your location to find nearby places and attractions."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ExploreEase needs camera access to scan QR codes and take photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ExploreEase needs photo access to upload review and profile images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A90D9",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ]
    ],
    "extra": {}
  }
}
